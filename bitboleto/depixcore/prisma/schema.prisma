// DepixCore — Schema do banco de dados
// Banco separado do PagDepix (read-only em relação ao PagDepix)
// Armazena eventos brutos, eventos processados e agregações diárias

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// CAMADA 1: EVENTOS BRUTOS
// Armazena exatamente o que chegou do PagDepix, sem modificação.
// Idempotência garantida pelo deliveryId (X-PagDepix-Delivery-Id).
// ============================================================
model EventRaw {
  id          String   @id @default(uuid())

  // Identificação do evento
  eventType   String   // payment.received | payment.approved | payment.refused
                       // recharge.completed | recharge.refused | charge.paid
  source      String   @default("pagdepix") // fonte do evento

  // Payload completo sem modificação
  payloadJson String   // JSON serializado do body recebido

  // Campos extraídos do payload para facilitar queries
  transactionId String? // boleto id, recharge id, charge id
  txid          String? // txid do pagamento cripto (quando presente)
  isSandbox     Boolean @default(false)

  // Idempotência: deliveryId = X-PagDepix-Delivery-Id header
  deliveryId  String?  @unique

  // Status de processamento interno do DepixCore
  processed   Boolean  @default(false)
  processedAt DateTime?
  processError String? // erro ao processar, se houver

  createdAt   DateTime @default(now())

  // Relação com evento processado (1:1 opcional)
  processed_event EventProcessed?

  @@index([eventType])
  @@index([source])
  @@index([txid])
  @@index([transactionId])
  @@index([createdAt])
  @@index([processed])
  @@map("events_raw")
}

// ============================================================
// CAMADA 2: EVENTOS PROCESSADOS
// Versão estruturada e enriquecida do evento bruto.
// Extraída pelo aggregation service para análise financeira.
// ============================================================
model EventProcessed {
  id          String   @id @default(uuid())

  // Referência ao evento bruto original (1:1)
  rawEventId  String   @unique
  rawEvent    EventRaw @relation(fields: [rawEventId], references: [id])

  // Classificação da transação
  eventType        String  // mesmo que EventRaw.eventType
  transactionType  String  // boleto | recharge | charge
  transactionId    String? // id da transação no PagDepix
  txid             String?

  // Dados financeiros extraídos do payload
  amount      Float?  // valor do boleto/recarga/charge em R$
  fee         Float?  // taxa cobrada em R$
  totalAmount Float?  // amount + fee
  cost        Float?  // custo operacional estimado (1% + 0,99)
  netProfit   Float?  // fee - cost

  // Referência externa (externalRef do PagDepix)
  externalRef String?

  // Status da transação no momento do evento
  status      String?

  // Moeda e cripto
  currency    String? // DEPIX | USDT | BTC
  cryptoAmount String?
  exchangeRate Float?

  // Flags
  isSandbox   Boolean @default(false)

  // Timestamps
  eventTimestamp DateTime? // timestamp do payload
  processedAt    DateTime  @default(now())

  @@index([eventType])
  @@index([transactionType])
  @@index([transactionId])
  @@index([processedAt])
  @@index([isSandbox])
  @@map("events_processed")
}

// ============================================================
// CAMADA 3: AGREGAÇÃO DIÁRIA
// Sumariza métricas financeiras por dia para queries rápidas.
// Atualizada incrementalmente a cada evento processado.
// ============================================================
model DailyAggregation {
  id     String   @id @default(uuid())
  date   String   // formato: YYYY-MM-DD
  source String   @default("pagdepix")

  // Contagens
  totalEvents      Int @default(0)
  approvedCount    Int @default(0)
  refusedCount     Int @default(0)
  receivedCount    Int @default(0)

  // Por tipo de transação
  boletoCount      Int @default(0)
  rechargeCount    Int @default(0)
  chargeCount      Int @default(0)

  // Financeiro (apenas eventos aprovados/completados)
  grossVolume      Float @default(0) // soma dos amounts aprovados
  totalFees        Float @default(0) // soma das fees aprovadas
  estimatedCosts   Float @default(0) // custo operacional estimado
  netProfit        Float @default(0) // totalFees - estimatedCosts

  // Sandbox separado de produção
  sandboxCount     Int   @default(0)
  sandboxVolume    Float @default(0)

  updatedAt DateTime @updatedAt

  @@unique([date, source])
  @@index([date])
  @@map("daily_aggregations")
}

// ============================================================
// CAMADA 5: USUÁRIOS DO PAINEL
// Equipe de contabilidade com acesso ao dashboard.
// ============================================================
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("viewer") // viewer | admin
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@map("users")
}

// ============================================================
// CAMADA 4: LOG DE AUDITORIA
// Registra todas as requisições recebidas no DepixCore.
// Inclui tentativas inválidas (HMAC inválido, IP desconhecido).
// ============================================================
model AuditLog {
  id          String   @id @default(uuid())

  // Requisição
  method      String   // GET | POST | etc.
  path        String
  ip          String?
  userAgent   String?

  // Resultado
  statusCode  Int
  error       String?  // mensagem de erro, se houver

  // Evento relacionado (se for webhook)
  eventType   String?
  deliveryId  String?
  rawEventId  String?

  createdAt   DateTime @default(now())

  @@index([path])
  @@index([statusCode])
  @@index([createdAt])
  @@index([eventType])
  @@map("audit_logs")
}
