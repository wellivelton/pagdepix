  @@index([sellerId])
  @@index([code, isActive])
}

model MarketplaceBanner {
  id                  String    @id @default(uuid())

  desktopImageUrl     String    @db.VarChar(500)
  desktopLinkType     String    @db.VarChar(20)
  desktopLinkTarget   String?   @db.VarChar(500)

  mobileImageUrl      String    @db.VarChar(500)
  mobileLinkType      String    @db.VarChar(20)
  mobileLinkTarget    String?   @db.VarChar(500)

  isActive            Boolean   @default(true)
  displayOrder        Int       @default(0)

