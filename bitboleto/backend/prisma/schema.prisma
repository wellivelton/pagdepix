// ========================================
// API WHITE-LABEL
// ========================================

model ApiKey {
  id          String   @id @default(uuid())
  affiliateId String
  label       String
  keyHash     String   @unique
  secretHash  String
  keyPrefix   String
  isSandbox   Boolean  @default(false)
  isActive    Boolean  @default(true)
  suspendedAt DateTime?
  suspendedReason String?
  ipWhitelist String[]
  rateLimit   Int      @default(60)
  lastUsedAt  DateTime?
  requestCount Int     @default(0)
  createdAt   DateTime @default(now())

  affiliate    Affiliate      @relation(fields: [affiliateId], references: [id])
  boletos      Boleto[]
  recharges    MobileRecharge[]
  pixCopiaCola PixCopiaCola[]
  webhookEndpoints WebhookEndpoint[]
  apiRequestLogs   ApiRequestLog[]

  @@index([keyHash])
  @@index([affiliateId])
  @@map("api_keys")
}

model WebhookEndpoint {
  id          String   @id @default(uuid())
  affiliateId String
  apiKeyId    String
  url         String
  secret      String
  events      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  affiliate  Affiliate          @relation(fields: [affiliateId], references: [id])
  apiKey     ApiKey             @relation(fields: [apiKeyId], references: [id])
  deliveries WebhookDelivery[]

  @@index([affiliateId])
  @@index([apiKeyId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id             String   @id @default(uuid())
  endpointId     String
  event          String
  transactionId  String?  // Para deduplicação e auditoria
  payload        String
  responseStatus Int?
  responseBody   String?
  attempts       Int      @default(0)
  maxAttempts    Int      @default(5)
  nextRetryAt    DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId])
  @@index([event])
  @@index([nextRetryAt])
  @@index([endpointId, event, transactionId])
  @@map("webhook_deliveries")
}

model ApiRequestLog {
  id        String   @id @default(uuid())
  apiKeyId  String
  method    String
  path      String
  statusCode Int
  ip        String
  userAgent String?
  duration  Int
  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
  @@map("api_request_logs")
}

