// ========================================
// AFFILIATE API CONFIG
// ========================================

model AffiliateApiConfig {
  id                      String    @id @default(uuid())
  affiliateId             String    @unique

  // Status de integração (nível do afiliado, não por chave)
  status                  String    @default("inactive")
  // inactive | beta | active | blocked

  // Limites
  globalDailyLimitPerUser Float     @default(1000.00)  // Limite diário POR usuário final
  maxDailyVolumeAffiliate Float?                       // Limite TOTAL diário do afiliado (null = sem limite)

  // Timestamps de auditoria
  activatedAt             DateTime?
  activatedByAdminId      String?
  activatedByAdminEmail   String?

  blockedAt               DateTime?
  blockedReason           String?
  blockedByAdminId        String?
  blockedByAdminEmail     String?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  affiliate               Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("affiliate_api_configs")
}

// ========================================
// API END USER LIMIT
// ========================================

model ApiEndUserLimit {
  id                  String    @id @default(uuid())
  affiliateId         String

  // Identificador do usuário no sistema do afiliado (CPF, externalRef, email, etc.)
  userRef             String

  // Limite personalizado (null = usa globalDailyLimitPerUser do AffiliateApiConfig)
  dailyLimit          Float?
  customLimitReason   String?

  // Bloqueio
  isActive            Boolean   @default(true)
  blockedReason       String?
  blockedAt           DateTime?
  blockedByAdminId    String?
  blockedByAdminEmail String?

  // Tracking de uso (reseta diariamente via cron)
  usedToday           Float     @default(0)
  lastUsageDate       String?   // YYYY-MM-DD
  usedThisMonth       Float     @default(0)
  monthResetDate      String?   // YYYY-MM

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  affiliate           Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, userRef])
  @@index([affiliateId])
  @@index([lastUsageDate])
  @@map("api_end_user_limits")
}

// ========================================
// REFERRAL — Programa de Indicação
// ========================================
model ReferralEarning {
  id           String   @id @default(cuid())
  earnerId     String
  earner       User     @relation("ReferralEarner", fields: [earnerId], references: [id])
  sourceUserId String
  sourceUser   User     @relation("ReferralSource", fields: [sourceUserId], references: [id])
  boletoId       String?
  rechargeId     String?
  pixCopiaColaId String?
  feeAmount      Float    // Taxa que o indicado pagou
  commission   Float    // 40% da taxa — crédito do indicador
  status       String   @default("AVAILABLE")
  createdAt    DateTime @default(now())

  @@index([earnerId])
  @@index([sourceUserId])
  @@map("referral_earnings")
}

// ========================================
// BOLETO BATCH — Pagamento unificado de múltiplos boletos
// ========================================
model BoletoBatch {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  itemCount       Int                        // quantidade de boletos
  totalBoletos    Float                      // soma dos valores dos boletos (sem taxas)
  totalFee        Float                      // soma das taxas
  grandTotal      Float                      // totalBoletos + totalFee (valor a pagar em crypto)
  walletAddress   String?
  qrCode          String?
  paymentCurrency String   @default("DEPIX")
  cryptoAmount    String?                    // valor exato em crypto (precisão de string)
  depixAmount     Float?
  exchangeRate    Float?
  rateLockExpiresAt DateTime?
  couponCode         String?
  liquidAddressIndex Int?   @unique
  status          String   @default("PENDING") // PENDING | PAID | CANCELLED | PROBLEM
  txid            String?  @unique
  receiptUrl      String?
  createdAt       DateTime @default(now())
  paidAt          DateTime?
  confirmedAt     DateTime?

  boletos         Boleto[] @relation("BoletoBatchItems")

  @@index([userId])
  @@index([status])
  @@map("boleto_batches")
}

// ========================================
// WEB PUSH NOTIFICATIONS
// ========================================

/** Assinaturas Web Push de dispositivos dos usuários. */
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

/** Histórico de notificações por usuário (central de notificações). */
model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("user_notifications")
}

model UserPushPreference {
  userId    String   @id
  status    String   @default("default")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_push_preferences")
}

// ========================================
// WEBHOOK IDEMPOTENCY
// ========================================

/** Tracks every inbound webhook event to prevent double-processing on gateway retries. */
model WebhookIdempotencyKey {
  id           String   @id @default(uuid())
  source       String   // "telegram" | "geradepix" | "velora"
  eventType    String   // e.g. "payment.paid", "withdrawal.completed", "telegram.update"
  externalId   String   // payment_id / withdrawal_id / externalId / update_id (as string)
  payloadHash  String   // sha256 of JSON.stringify(payload) — extra replay defence
  processedAt  DateTime @default(now())
  result       String   // "pending" | "ok" | "error" | "ignored_duplicate"
  errorMessage String?

  @@unique([source, eventType, externalId])
  @@index([processedAt])
  @@map("webhook_idempotency_keys")
}

// ========================================
// SIDESWAP — Liquid Network DEX
// ========================================

// Status: pending_deposit → broadcasting → completed → failed → refunded
model SideswapSwap {
  id               String   @id @default(uuid())
  userId           String
  status           String   @default("pending_deposit")
  depositAsset     String
  settleAsset      String
  depositAmount    Decimal? @db.Decimal(20, 8)
  settleAmount     Decimal? @db.Decimal(20, 8)
  settleAddress    String
  depositAddress   String?
  depositTxid      String?
  settleTxid       String?
  sideswapOrderId  String?
  errorMessage     String?
  refundAddress    String?
  refundRequestAt  DateTime?
  rawQuote         Json?
  rawPset          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("sideswap_swaps")
}

