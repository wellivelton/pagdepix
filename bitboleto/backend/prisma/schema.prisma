// ========================================
// LEGACY MarketplaceOrder (manter compatibilidade)
// ========================================

model ProductFile {
  id                String    @id @default(uuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  filename          String    @db.VarChar(255)
  originalFilename  String    @db.VarChar(255)
  filePath          String    @db.VarChar(500)
  fileSize          BigInt
  mimeType          String?   @db.VarChar(100)

  fileHash          String?   @db.VarChar(64)
  virusScanStatus   String    @default("pending")
  virusScanResult   String?   @db.Text
  virusScanAt       DateTime?

  uploadedAt        DateTime  @default(now())

  @@index([productId])
}

model ProductCode {
  id                String             @id @default(uuid())
  productId         String
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  code              String             @db.VarChar(500)
  isUsed            Boolean            @default(false)
  usedByOrderId     String?
  usedByOrder       MarketplaceOrder?  @relation(fields: [usedByOrderId], references: [id])
  usedByOrderItemId String?
  usedByOrderItem   OrderItem?         @relation(fields: [usedByOrderItemId], references: [id])
  usedAt            DateTime?

  createdAt         DateTime           @default(now())

  @@index([productId, isUsed])
  @@index([usedByOrderItemId])
}

model MarketplaceOrder {
  id                    String    @id @default(uuid())
  buyerId               String
  buyer                 User      @relation("BuyerOrders", fields: [buyerId], references: [id])
  productId             String
  product               Product   @relation(fields: [productId], references: [id])
  sellerId              String
  seller                User      @relation("SellerOrders", fields: [sellerId], references: [id])

  productPrice          Float
  platformFee           Float
  platformFixedFee      Float
  affiliateCommission   Float     @default(0)
  couponDiscount        Float     @default(0)
  finalPrice            Float
  sellerReceives        Float

  swapverseOrderId      String?   @unique @db.VarChar(100)
  paymentStatus         String    @default("pending")
  paidAt                DateTime?

  deliveryStatus        String    @default("pending")
  deliveredAt           DateTime?
  deliveredCode         String?   @db.VarChar(500)
  downloadLink          String?   @db.Text
  downloadLinkExpiry    DateTime?
  downloadCount         Int       @default(0)
  downloadLimit         Int       @default(3)

  disputeStatus         String?
  disputeReason         String?   @db.Text
  disputeOpenedAt       DateTime?
  disputeResolvedAt     DateTime?
  disputeResolvedBy     String?
  disputeResolver       User?     @relation("DisputeResolver", fields: [disputeResolvedBy], references: [id])
  disputeAdminNotes     String?   @db.Text

  settlementStatus      String    @default("pending")
  settlementAvailableAt DateTime?
  settlementPaidAt      DateTime?

  couponId              String?
  coupon                SellerCoupon? @relation(fields: [couponId], references: [id])
  affiliateId           String?
  affiliate             Affiliate?    @relation(fields: [affiliateId], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  usedCodes             ProductCode[]
  review                ProductReview?
  chatMessages          OrderChatMessage[]

  @@index([buyerId, paymentStatus])
  @@index([sellerId, settlementStatus])
  @@index([productId])
  @@index([paymentStatus])
  @@index([settlementStatus])
  @@index([disputeStatus])
  @@index([createdAt])
}

model OrderChatMessage {
  id              String           @id @default(uuid())
  orderId         String
  order           MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  messageType     String           @default("TEXT") @db.VarChar(20)
  content         String?          @db.Text
  attachmentPath  String?          @db.VarChar(500)
  attachmentName  String?          @db.VarChar(255)
  attachmentSize  Int?
  attachmentMime  String?          @db.VarChar(100)

  isFromAdmin     Boolean          @default(false)
  adminIntervention Boolean        @default(false)

  createdAt       DateTime         @default(now())

  @@index([orderId])
  @@index([senderId])
  @@index([createdAt])
}

model ProductReview {
  id              String             @id @default(uuid())
  productId       String
  product         Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  orderId         String             @unique
  order           MarketplaceOrder   @relation(fields: [orderId], references: [id])

  rating          Int
  comment         String?            @db.Text

  isApproved      Boolean            @default(false)
  approvedAt      DateTime?
  approvedBy      String?
  approvedByUser  User?              @relation("ReviewApprovals", fields: [approvedBy], references: [id])
  rejectionReason String?            @db.Text

  createdAt       DateTime           @default(now())

  @@index([productId, isApproved])
  @@index([userId])
}

model SellerCoupon {
  id              String    @id @default(uuid())
  sellerId        String
  seller          User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  code            String    @unique @db.VarChar(50)
  discountPercent Float

  isActive        Boolean   @default(true)
  usageCount      Int       @default(0)
  maxUsage        Int?
