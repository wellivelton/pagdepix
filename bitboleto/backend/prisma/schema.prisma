model SellerBalanceTransaction {
  id            String   @id @default(uuid())
  sellerId      String
  seller        User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type          String   @db.VarChar(50)   // SALE_CREDIT, WITHDRAWAL, ADJUSTMENT, REFUND, FEE
