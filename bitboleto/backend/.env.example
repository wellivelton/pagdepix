# =============================================================================
# PagdePix Backend — Environment Variables
# Copy this file to .env and fill in all required values before starting.
# =============================================================================

# =============================================================================
# REQUIRED — Server CRASHES on startup if any of these are missing or invalid
# =============================================================================

# JWT signing secret — minimum 32 chars, cryptographically random.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NEVER use: "segredo", "supersecret", "seu-secret-aqui", "changeme" or any short value.
JWT_SECRET=<generate-with-crypto.randomBytes-48-toString-hex>

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/pagdepix

# Liquid Network wallet address for receiving platform payments.
# Must be a Liquid mainnet address (NOT a Bitcoin address).
# DO NOT copy the example from source code — use your own wallet address.
LIQUID_WALLET_ADDRESS=<your-liquid-mainnet-address>

# Liquid HD wallet extended public key for address derivation (xpub/ypub/zpub/Mtub).
LIQUID_XPUB=<your-liquid-xpub>

# Liquid master blinding key — exactly 64 hex characters (32 bytes).
# Generate from your wallet seed; keep secret.
LIQUID_MASTER_BLINDING_KEY=<64-hex-chars>

# GeraDePix API key — required for all PIX send/receive operations. Min 16 chars.
# Docs: https://telegra.ph/DOCUMENTA%C3%87%C3%83O-API-geradepixbot-03-02
GERADEPIX_API_KEY=<your-geradepix-api-key>

# =============================================================================
# OPTIONAL — Features degrade gracefully; a warning is logged at startup if absent
# =============================================================================

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram webhook secret (X-Telegram-Bot-Api-Secret-Token header)
TELEGRAM_WEBHOOK_SECRET=
# Admin Telegram chat ID for operational alerts
TELEGRAM_ADMIN_CHAT_ID=

# Resend transactional email API key
RESEND_API_KEY=

# VAPID keys for Web Push notifications.
# Generate: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:contato@pagdepix.com

# Asaas — futuro provider de recarga de celular e pagamento de boletos
ASAAS_API_KEY=
# "sandbox" for testing; anything else = production
ASAAS_ENV=production
# Token configurado no dashboard Asaas → Integrações → Webhooks (Pague Contas)
ASAAS_WEBHOOK_TOKEN=

# SwapVerse integration (DEPIX swap)
SWAPVERSE_ACCESS_TOKEN=
SWAPVERSE_API_URL=https://api.swapverse.exchange
SWAPVERSE_PAGDEPIX_FEE_PERCENT=0

# Velora notifications
VELORA_API_KEY=
VELORA_API_SECRET=
VELORA_BASE_URL=https://api.velora.notiffly.com.br
VELORA_WEBHOOK_SECRET=

# DepixCore webhook forwarding
DEPIXCORE_WEBHOOK_URL=
DEPIXCORE_WEBHOOK_SECRET=

# NewsData.io for news feed
NEWSDATA_API_KEY=

# VPN detection (optional anti-fraud)
VPN_API_URL=
VPN_API_KEY=

# =============================================================================
# OPERATIONAL — Safe defaults exist; override only if needed
# =============================================================================

PORT=3001
NODE_ENV=production

# Public URLs
FRONTEND_URL=https://pagdepix.com
APP_URL=https://api.pagdepix.com
BACKEND_URL=https://api.pagdepix.com

# Extra CORS origins (comma-separated, beyond built-in defaults)
CORS_ORIGINS=

# Rate limiter IP whitelist (comma-separated)
RATE_LIMIT_WHITELIST=

# Liquid Network settings
MIN_LIQUID_CONFIRMATIONS=2
ESPLORA_BASE_URL=https://blockstream.info/liquid/api

# Liquid mainnet asset IDs — do NOT change unless using testnet
DEPIX_ASSET_ID=02f22f8d9c76ab41661a2729e4752e2c5d1a263012141b86ea98af5472df5189
USDT_ASSET_ID=ce091c998b83c78bb71a632313ba3760f1763d9cfcffae02258ffa9865a37bd2
LBTC_ASSET_ID=6f0279e9ed041c3d710a9f57d0c02928416460c4b722ae3457a11eec381c526d

# PIX Copia e Cola limits
MAX_PCC_AMOUNT=10000
MAX_PCC_PENDING_PER_USER=3

# Feature flags
ENABLE_EMAIL_AND_TELEGRAM_VERIFICATION=false

# News cache TTL in seconds
NEWS_CACHE_TTL_SECONDS=1800
NEWS_RSS_CACHE_TTL_SECONDS=900

# Bot transaction limits
LIMITE_NOVO_USUARIO=100
LIMITE_APOS_7_DIAS=500
DIAS_LIMITE_NOVO=7
BOT_FEE_PERCENT=2
BOT_FEE_FIXED=0.99
DEPIX_FIXED_FEE=0.99

# SQLite path for bot database (default: data/bot.db relative to backend root)
BOT_DB_PATH=

# =============================================================================
# SEED (only for: npx prisma db seed)
# =============================================================================
# ADMIN_EMAIL=admin@pagdepix.com
# ADMIN_NAME=Administrador
# ADMIN_TELEGRAM=@seu_telegram
# ADMIN_PASSWORD=senha_forte_aqui

# ========================================
# SIDESWAP — Liquid Network DEX
# ========================================
SIDESWAP_WS_URL="wss://api-testnet.sideswap.io/json-rpc-ws"   # testnet
# SIDESWAP_WS_URL="wss://api.sideswap.io/json-rpc-ws"         # mainnet
SIDESWAP_TESTNET=true
LIQUID_MNEMONIC=""   # BIP39 24 words — gerar com: node -e "const b=require('bip39');console.log(b.generateMnemonic(256))"
SWAP_MARGIN_PERCENT=0.5  # margem da plataforma retida como change output (0 = desativado)
